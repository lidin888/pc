+
+  # Git子模块（在独立模式下可选）
+  if [[ -d ".git" ]] && [[ -z "$STANDALONE" || ! -z "$FORCE_GIT" ]]; then
+    echo "Getting git submodules..."
+    st="$(date +%s)"
