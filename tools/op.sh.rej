 }
 
 
@@ -428,6 +474,8 @@ function _op() {
   # parse Options
   case $1 in
     -d | --dir )       shift 1; OPENPILOT_ROOT="$1"; shift 1 ;;
+    --standalone )     shift 1; STANDALONE="1" ;;
+    --force-git )      shift 1; FORCE_GIT="1" ;;
     --dry )            shift 1; DRY="1" ;;
     -n | --no-verify ) shift 1; NO_VERIFY="1" ;;
     -l | --log )       shift 1; LOG_FILE="$1" ; shift 1 ;;
