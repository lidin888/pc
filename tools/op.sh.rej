+  # 独立模式下，可选地跳过某些步骤
+  if [[ -z "$STANDALONE" ]]; then
+    echo "Installing dependencies..."
+    st="$(date +%s)"
+    if [[ "$OSTYPE" == "linux-gnu"* ]]; then
+      SETUP_SCRIPT="tools/ubuntu_setup.sh"
+    elif [[ "$OSTYPE" == "darwin"* ]]; then
+      SETUP_SCRIPT="tools/mac_setup.sh"
